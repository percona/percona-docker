FROM oraclelinux:9 AS downloader

RUN yum install -y epel-release; \
    yum config-manager --set-enabled ol9_codeready_builder; \
    yum install -y --downloadonly perl-JSON hdf5 xerces-c netcdf libaec libarrow libgta freexl libdeflate cfitsio armadillo gpsbabel libqhull_r boost-serialization minizip libkml librttopo; \
    mkdir -p downloaded-packages; \
    cp -rp /var/cache/dnf/ol9_appstream-*/packages/*.rpm downloaded-packages; \
    cp -rp /var/cache/dnf/ol9_baseos_latest*/packages/*.rpm downloaded-packages; \
    cp -rp /var/cache/dnf/ol9_developer_EPEL*/packages/*.rpm downloaded-packages; \
    cp -rp /var/cache/dnf/ol9_codeready_builder*/packages/*.rpm downloaded-packages; \
    yum install -y --downloadonly --downloaddir=downloaded-packages libssh2; \
    cd downloaded-packages; \
    rm -rf pcre2* brotli* dbus*; \
    cd -; \
    tar -cvzf downloaded-packages.tar.gz downloaded-packages

FROM redhat/ubi9-minimal

LABEL name="Percona PostgreSQL Distribution upgrade" \
    vendor="Percona" \
    summary="Percona Distribution for PostgreSQL" \
    description="Percona Distribution for PostgreSQL is a collection of tools to assist you in managing your PostgreSQL database system" \
    maintainer="Percona Development <info@percona.com>"

RUN set -ex; \
    microdnf -y update; \
    microdnf -y install glibc-langpack-en platform-python tar; \
    microdnf clean all; \
    rm -rf /var/cache/dnf /var/cache/yum

ENV LC_ALL en_US.utf-8
ENV LANG en_US.utf-8
ARG PG_MAJOR=18

RUN set -ex; \
    export GNUPGHOME="$(mktemp -d)"; \
    gpg --batch --keyserver keyserver.ubuntu.com --recv-keys \
        4D1BB29D63D98E422B2113B19334A25F8507EFA5 \
        3E6D826D3FBAB389C2F38E34BC4D06A08D8B756F \
        99DB70FAE1D7CE227FB6488205B555B38483C65D; \
    gpg --batch --export --armor 4D1BB29D63D98E422B2113B19334A25F8507EFA5 > ${GNUPGHOME}/PERCONA-PACKAGING-KEY; \
    gpg --batch --export --armor 99DB70FAE1D7CE227FB6488205B555B38483C65D > ${GNUPGHOME}/RPM-GPG-KEY-centosofficial; \
    gpg --batch --export --armor 3E6D826D3FBAB389C2F38E34BC4D06A08D8B756F > ${GNUPGHOME}/RPM-GPG-KEY-oracle; \
    gpg --batch --export --armor 3E6D826D3FBAB389C2F38E34BC4D06A08D8B756F > /etc/pki/rpm-gpg/RPM-GPG-KEY-oracle; \
    rpmkeys --import \
        ${GNUPGHOME}/PERCONA-PACKAGING-KEY \
        ${GNUPGHOME}/RPM-GPG-KEY-oracle \
        ${GNUPGHOME}/RPM-GPG-KEY-centosofficial; \
    microdnf install -y findutils yum-utils; \
    ARCH=$(uname -m); \
    curl -Lf -o /tmp/oraclelinux-release.rpm https://yum.oracle.com/repo/OracleLinux/OL9/baseos/latest/${ARCH}/getPackage/oraclelinux-release-el9-1.0-15.el9.${ARCH}.rpm; \
    curl -Lf -o /tmp/epel-release.rpm https://yum.oracle.com/repo/OracleLinux/OL9/baseos/latest/${ARCH}/getPackage/oracle-epel-release-el9-1.0-1.el9.${ARCH}.rpm; \
    curl -Lf -o /tmp/percona-release.rpm https://repo.percona.com/yum/percona-release-latest.noarch.rpm; \
    rpm --import ${GNUPGHOME}/PERCONA-PACKAGING-KEY ${GNUPGHOME}/RPM-GPG-KEY-oracle ${GNUPGHOME}/RPM-GPG-KEY-centosofficial; \
    rpmkeys --checksig /tmp/percona-release.rpm; \
    rpmkeys --checksig /tmp/epel-release.rpm; \
    rpmkeys --checksig /tmp/oraclelinux-release.rpm; \
    rpm -i /tmp/percona-release.rpm /tmp/oraclelinux-release.rpm /tmp/epel-release.rpm; \
    rm -rf "$GNUPGHOME" /tmp/percona-release.rpmm /tmp/oraclelinux-release.rpm /tmp/epel-release.rpm; \
    percona-release enable ppg-${PG_MAJOR} release; \
    percona-release enable ppg-${PG_MAJOR}-extras testing

RUN set -ex; \
    yum-config-manager --disable ol9_appstream; \
    microdnf -y clean all

RUN set -ex; \
    ARCH=$(uname -m); \
    microdnf --enablerepo="ol9_appstream" -y install \
        annobin-12.31-2.el9.${ARCH}; \
    microdnf -y clean all

RUN set -ex; \
    microdnf -y install \
        bind-utils \
        gettext \
        hostname \
        python3-pyparsing \
        perl \
        libedit \
        pcre2-utf16 \
        brotli \
        dbus-libs \
        procps-ng; \
    microdnf -y install \
        libpq \
        percona-postgresql${PG_MAJOR//.}; \
    microdnf -y clean all; \
    rm -rf /var/cache/dnf /var/cache/yum

COPY --from=downloader /downloaded-packages.tar.gz .
RUN tar -xvzf downloaded-packages.tar.gz; \
        cd downloaded-packages; \
        rpm -Uvh --replacepkgs *.rpm; \
        rpm -ivh libssh2*.rpm; \
        rm -f /downloaded-packages.tar.gz; \
        cd -; \
        rm -rf /downloaded-packages /var/cache/dnf /var/cache/yum

RUN set -ex; \
    percona-release enable ppg-${PG_MAJOR}-extras testing; \
    microdnf -y install --nodocs\
        --enablerepo="ol9_developer_EPEL" \
        percona-postgresql${PG_MAJOR//.}-contrib \
        percona-postgresql${PG_MAJOR//.}-server \
        percona-postgresql${PG_MAJOR//.}-libs \
        percona-postgresql${PG_MAJOR//.}-llvmjit \
        percona-timescaledb_${PG_MAJOR//.} \
        percona-h3-pg_${PG_MAJOR//.} \
        nss_wrapper \
        lz4 \
        unzip;

RUN set -ex; \
    percona-release enable ppg-${PG_MAJOR} release; \
    microdnf -y install --nodocs\
        percona-pgaudit${PG_MAJOR//.} \
        percona-pgaudit${PG_MAJOR//.}_set_user \
        percona-wal2json${PG_MAJOR//.} \
        percona-pg_stat_monitor${PG_MAJOR//.} \
        percona-pgvector_${PG_MAJOR//.} \
        percona-pgvector_${PG_MAJOR//.}-llvmjit \
        percona-pg_repack${PG_MAJOR//.} \
        percona-postgis35_${PG_MAJOR//.} \
        percona-postgis35_${PG_MAJOR//.}-client \
        percona-postgis35_${PG_MAJOR//.}-llvmjit \
        percona-postgis35_${PG_MAJOR//.}-utils \
        percona-pgrouting_${PG_MAJOR//.} \
        percona-pg_similarity_${PG_MAJOR//.} \
        percona-rum_${PG_MAJOR//.} \
        percona-postgresql-unit_${PG_MAJOR//.} \
        percona-ip4r_${PG_MAJOR//.} \
        percona-pg_cron_${PG_MAJOR//.} \
        percona-hll_${PG_MAJOR//.} \
        percona-postgresql_anonymizer_${PG_MAJOR//.} \
        percona-pgvectorscale_${PG_MAJOR//.} \
        percona-pg_partman_${PG_MAJOR//.}; \
    if [[ "${PG_MAJOR//.}" -ge 18 ]]; then \
        microdnf -y install percona-pg_oidc_validator${PG_MAJOR//.}; \
    fi; \
    microdnf -y reinstall tzdata; \
    microdnf clean all; \
    rm -rf /var/cache/dnf /var/cache/yum

RUN set -ex; \
for pg_version in 17 16; do \
    percona-release enable ppg-${pg_version}-extras testing; \
    microdnf -y install --nodocs \
        percona-postgresql${pg_version}-contrib \
        percona-postgresql${pg_version}-server \
        percona-postgresql${pg_version}-libs \
        percona-postgresql${pg_version}-llvmjit; \
done

RUN set -ex; \
    for pg_version in 17 16; do \
        percona-release enable ppg-${pg_version} release; \
        microdnf -y install --nodocs \
            percona-pgaudit${pg_version} \
            percona-pgaudit${pg_version}_set_user \
            percona-wal2json${pg_version} \
            percona-pg_stat_monitor${pg_version} \
            percona-pgvector_${pg_version} \
            percona-pgvector_${pg_version}-llvmjit \
            percona-postgis35_${pg_version} \
            percona-postgis35_${pg_version}-llvmjit \
            percona-pg_repack${pg_version} \
            percona-timescaledb_${pg_version} \
            percona-h3-pg_${pg_version} \
            percona-pgrouting_${pg_version} \
            percona-pg_similarity_${pg_version} \
            percona-rum_${pg_version} \
            percona-postgresql-unit_${pg_version} \
            percona-ip4r_${pg_version} \
            percona-pg_cron_${pg_version} \
            percona-hll_${pg_version} \
            percona-postgresql_anonymizer_${pg_version} \
            percona-pgvectorscale_${pg_version} \
            percona-pg_partman_${pg_version}; \
    done; \
    microdnf -y clean all; \
    rm -rf /var/cache/dnf /var/cache/yum

RUN mkdir -p /opt/crunchy/bin /pgolddata /pgnewdata /opt/crunchy/conf
COPY bin/upgrade/ /opt/crunchy/bin
COPY bin/common /opt/crunchy/bin
COPY conf/upgrade/ /opt/crunchy/conf
COPY bin/relocate-extensions.sh /usr/local/bin/relocate-extensions.sh

RUN chown -R postgres:postgres /opt/crunchy /pgolddata /pgnewdata && \
    chmod -R g=u /opt/crunchy /pgolddata /pgnewdata

VOLUME /pgolddata /pgnewdata

ENV NSS_WRAPPER_SUBDIR="upgrade"

ENTRYPOINT ["opt/crunchy/bin/uid_postgres.sh"]

USER 26

CMD ["/opt/crunchy/bin/start.sh"]
